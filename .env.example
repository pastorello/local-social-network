# Copy to .env and adjust. Used by docker compose; every variable has a safe
# development default in backend/backend/settings.py for bare-metal runs.

# --- Django ---
# Generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Public base URL of the backend (used to build absolute media URLs)
WEBSITE_URL=http://127.0.0.1:8000

# --- Postgres (setting POSTGRES_HOST switches Django from SQLite to Postgres) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
